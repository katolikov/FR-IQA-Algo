{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'static-only build'",
  "outputDirectory": "web/public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/paper",       "destination": "/paper.html" },
    { "source": "/api/(.*)",    "destination": "/api/proxy" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(index|paper).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/proxy.py": {
      "runtime": "python3.11",
      "maxDuration": 60
    }
  }
}
