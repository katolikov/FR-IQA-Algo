{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "echo 'static-only build'",
  "outputDirectory": "web/public",
  "installCommand": "echo 'no install'",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/paper",    "destination": "/paper.html" },
    { "source": "/api/:path*", "destination": "https://katolikov-upiqal-eval.hf.space/api/:path*" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(index|paper).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
