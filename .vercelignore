# Vercel deploys only the static frontend (web/public/) + api/proxy.py.
# Everything else below is excluded to keep the Vercel build artifact tiny
# and avoid accidentally shipping the full ML package / model weights.

upiqal/
weights/
tests/
analysis/
docs/
venv/
.venv/
upiqal_cli.py
upiqal_*_2026*
upiqal_*_2025*
upiqal_web_T*.png
upiqal_photo_compare_*
upiqal_results_*
upiqal_same_image_*
upiqal_spot_diff_*
upiqal_img2_*
input.png
left.png
right.png
image*.png
pyproject.toml
HOWTO.md
Dockerfile
fly.toml
render.yaml
.dockerignore
.DS_Store
# Python build artefacts — catch at every depth, including the repo
# root. The bare `__pycache__/` pattern Vercel was honouring in
# `.vercelignore` did not always anchor correctly, so we also spell out
# the common root-level and nested forms and extensions.
__pycache__
__pycache__/
**/__pycache__
**/__pycache__/
*.pyc
*.pyo
**/*.pyc
**/*.pyo
# Deploy build workspace (clone of the HF Space repo).
build/

# The Python proxy is no longer used — Vercel routes /api/* directly
# to the HF Space via a native rewrite in vercel.json. Ignore the
# whole api/ directory so Vercel's Python auto-detector doesn't try
# to build a FastAPI app from it.
api/

# Ignore Python manifests ANYWHERE under web/ and the rest of the repo
# so Vercel's framework auto-detector doesn't spin up a FastAPI build
# pipeline.  Only web/public/ static assets are actually deployed.
web/requirements.txt
web/main.py
web/mock_upiqal.py
web/__init__.py
requirements.txt
setup.py
setup.cfg
